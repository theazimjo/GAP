// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           Int      @id @default(autoincrement())
  name         String
  phone        String   @unique
  email        String?  @unique
  passwordHash String
  avatarUrl    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  ownedGroups  Group[]  @relation("GroupCreator")
  memberships  Membership[]
  receivedGaps Turn[]   @relation("GapReceiver")
  
  otpCode      String?
  otpExpiresAt DateTime?
}

model Group {
  id                 Int      @id @default(autoincrement())
  name               String
  totalPool          Decimal  @db.Decimal(12, 2)
  contributionAmount Decimal  @db.Decimal(12, 2)
  createdAt          DateTime @default(now())
  
  creatorId          Int
  creator            User     @relation("GroupCreator", fields: [creatorId], references: [id])
  
  members            Membership[]
  turns              Turn[]
}

model Membership {
  id      Int    @id @default(autoincrement())
  userId  Int
  groupId Int
  role    String @default("member") // "admin" or "member"

  user    User   @relation(fields: [userId], references: [id])
  group   Group  @relation(fields: [groupId], references: [id])

  payments Payment[]

  @@unique([userId, groupId])
}

model Turn {
  id        Int      @id @default(autoincrement())
  groupId   Int
  hostId    Int
  date      DateTime
  status    String   @default("pending") // "pending", "completed"
  
  group     Group    @relation(fields: [groupId], references: [id])
  host      User     @relation("GapReceiver", fields: [hostId], references: [id])

  payments  Payment[]
}

model Payment {
  id           Int      @id @default(autoincrement())
  turnId       Int
  membershipId Int
  amount       Decimal  @db.Decimal(12, 2)
  status       String   @default("unpaid") // "unpaid", "paid", "verified"
  timestamp    DateTime @default(now())

  turn         Turn       @relation(fields: [turnId], references: [id])
  membership   Membership @relation(fields: [membershipId], references: [id])
}
